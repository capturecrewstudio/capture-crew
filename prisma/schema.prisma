generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  EDITOR
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  BOOKED
  ARCHIVED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  projects  Project[]
  createdAt DateTime  @default(now())
}

model Project {
  id          String         @id @default(uuid())
  title       String
  slug        String         @unique
  description String?
  summary     String?
  narrative   String?
  location    String?
  year        String?
  client      String?
  services    Json           @default("[]")
  categoryId  String
  category    Category       @relation(fields: [categoryId], references: [id])
  coverImage  String?
  featured    Boolean        @default(false)
  images      ProjectImage[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([categoryId])
  @@index([featured])
}

model ProjectImage {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  imageUrl    String
  avifUrl     String?
  webpUrl     String?
  blurDataUrl String?
  sortOrder   Int      @default(0)
  altText     String?
  createdAt   DateTime @default(now())

  @@index([projectId])
}

model Media {
  id           String   @id @default(uuid())
  originalName String
  folder       String   @default("portfolio")
  variants     Json
  blurDataUrl  String
  createdAt    DateTime @default(now())

  @@index([folder])
  @@index([createdAt(sort: Desc)])
}

model Testimonial {
  id          String   @id @default(uuid())
  name        String
  designation String?
  message     String
  image       String?
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([featured])
}

model Lead {
  id        String     @id @default(uuid())
  name      String
  email     String
  phone     String?
  service   String
  message   String
  status    LeadStatus @default(NEW)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status])
  @@index([createdAt(sort: Desc)])
}

model BlogPost {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  excerpt     String?
  body        String
  coverImage  String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SeoSetting {
  id          String   @id @default(uuid())
  path        String   @unique
  title       String
  description String
  ogImage     String?
  canonical   String?
  structured  Json?
  updatedAt   DateTime @updatedAt
}

model SiteContent {
  id                  String   @id @default(uuid())
  heroHeadline        String   @default("Where Craft\nMeets Legacy")
  heroSubheadline     String   @default("Architecture. Luxury. Visual Storytelling.")
  heroCta1            String   @default("View Portfolio")
  heroCta2            String   @default("Book a Shoot")
  stats               Json     @default("{}")
  partners            Json     @default("[]")
  socialProofEyebrow  String   @default("Our Clients")
  socialProofHeadline String   @default("Brands That Trust Our Lens")
  faq                 Json     @default("[]")
  packages            Json     @default("[]")
  footerTagline       String   @default("")
  footerPhone         String   @default("")
  footerEmail         String   @default("")
  footerCities        String   @default("")
  contactHeadline     String   @default("Let's make something worth keeping.")
  contactSubheadline  String   @default("Tell us about your project and we'll get back to you within 24 hours.")
  socialDock          Json     @default("{}")
  updatedAt           DateTime @updatedAt
}
