PORT=4000

# ─── Database ────────────────────────────────────────────────────────────────
# Local:      postgresql://postgres:postgres@localhost:5432/capture_crew?schema=public
# Railway:    postgresql://user:pass@host:port/db?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/capture_crew?schema=public"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET="replace-with-openssl-rand-hex-32-output"

# ─── CORS ────────────────────────────────────────────────────────────────────
# Production: your Vercel deployment URL
CLIENT_ORIGIN="http://localhost:5173"

# ─── Cloudflare R2 Storage ───────────────────────────────────────────────────
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET="capture-crew-media"
R2_PUBLIC_URL="https://your-bucket.your-account.r2.dev"

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY="re_your_api_key"
STUDIO_EMAIL="hello@capturecrew.in"

# ─── First Admin User (seed only) ────────────────────────────────────────────
ADMIN_EMAIL="admin@capturecrew.in"
ADMIN_PASSWORD="change-this-strong-password"
