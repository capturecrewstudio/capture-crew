PORT=4000

# ─── Database ───────────────────────────────────────────────────────────────
# Local: postgresql://postgres:postgres@localhost:5432/capture_crew?schema=public
# Production (Neon): postgresql://user:pass@ep-xxx.neon.tech/capture_crew?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/capture_crew?schema=public"

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET="replace-with-a-long-random-secret"

# ─── CORS ────────────────────────────────────────────────────────────────────
CLIENT_ORIGIN="http://localhost:5173"

# ─── Cloudflare R2 Storage ───────────────────────────────────────────────────
# Dashboard: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET="capture-crew-media"
R2_PUBLIC_URL="https://your-bucket.your-account.r2.dev"
